PORT=3000
DATABASE_URL=postgres://localhost:5432/whatsapp_automation
JWT_SECRET=change-me
# Admin credentials. ADMIN_PASSWORD is plaintext here and is stored as a
# bcrypt hash when the admin account is seeded on first startup.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
# Set to false to run the API/admin panel without starting the WhatsApp client
WHATSAPP_ENABLED=true
